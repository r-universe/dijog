[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "DiscreteMorseR"]
	path = DiscreteMorseR
	url = https://github.com/dijog/discretemorser
[submodule "MultiModalR"]
	path = MultiModalR
	url = https://github.com/dijog/multimodalr
[submodule "ahull3D"]
	path = ahull3D
	url = https://github.com/dijog/ahull3d
